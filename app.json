{
  "expo": {
    "name": "Quran Pesat",
    "slug": "quran-pesat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logoh.png",
    "scheme": "quranpesat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/logoh.png",
        "backgroundImage": "./assets/logo/logoh.png",
        "monochromeImage": "./assets/logo/logoh.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.raple.quranpesat"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/logoh.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/logoh.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6e17f66a-f5c9-4283-8472-02d9cef71643"
      }
    },
    "owner": "raple"
  }
}
